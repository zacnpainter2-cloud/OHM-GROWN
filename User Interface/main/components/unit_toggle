import { createContext, useContext, useState, ReactNode } from "react";

interface UnitContextType {
  tempUnit: "F" | "C";
  waterLevelUnit: "cm" | "in";
  setTempUnit: (unit: "F" | "C") => void;
  setWaterLevelUnit: (unit: "cm" | "in") => void;
}

const UnitContext = createContext<UnitContextType | undefined>(undefined);

export function UnitProvider({ children }: { children: ReactNode }) {
  const [tempUnit, setTempUnit] = useState<"F" | "C">("C"); // Default to Celsius since sensor sends Celsius
  const [waterLevelUnit, setWaterLevelUnit] = useState<"cm" | "in">("in"); // Default to inches

  return (
    <UnitContext.Provider
      value={{
        tempUnit,
        waterLevelUnit,
        setTempUnit,
        setWaterLevelUnit,
      }}
    >
      {children}
    </UnitContext.Provider>
  );
}

export function useUnits() {
  const context = useContext(UnitContext);
  if (context === undefined) {
    throw new Error("useUnits must be used within a UnitProvider");
  }
  return context;
}
