import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "./ui/card";
import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, Legend, ReferenceLine } from "recharts";
import { Badge } from "./ui/badge";
import { useSensorData } from "../hooks/useSensorData";
import { useMemo } from "react";
import { StatisticsCard } from "./StatisticsCard";

export function ECPage() {
  const { readings, latestReading, isLoading } = useSensorData();

  // Filter readings to last 24 hours
  const filteredReadings = useMemo(() => {
    const now = Date.now();
    const twentyFourHoursAgo = now - (24 * 60 * 60 * 1000);
    return readings.filter((r) => r.timestamp >= twentyFourHoursAgo);
  }, [readings]);

  // Transform sensor readings for the chart
  const chartData = useMemo(() => {
    return filteredReadings.map(reading => ({
      time: new Date(reading.timestamp).toLocaleTimeString('en-US', { 
        hour: '2-digit', 
        minute: '2-digit' 
      }),
      ec: reading.ec,
      timestamp: reading.timestamp,
      ecDosing: reading.ecDosingFlag === 1,
    }));
  }, [filteredReadings]);

  // Detect EC dosing start/stop events
  const dosingEvents = useMemo(() => {
    const events: Array<{ time: string; type: 'start' | 'stop' | 'active'; timestamp: number }> = [];
    
    // Check if dosing is already active at the start of the dataset
    if (chartData.length > 0 && chartData[0].ecDosing) {
      events.push({ 
        time: chartData[0].time, 
        type: 'active', 
        timestamp: chartData[0].timestamp 
      });
    }
    
    for (let i = 1; i < chartData.length; i++) {
      const prev = chartData[i - 1];
      const curr = chartData[i];
      
      // Dosing started
      if (!prev.ecDosing && curr.ecDosing) {
        events.push({ time: curr.time, type: 'start', timestamp: curr.timestamp });
      }
      // Dosing stopped
      if (prev.ecDosing && !curr.ecDosing) {
        events.push({ time: curr.time, type: 'stop', timestamp: curr.timestamp });
      }
    }
    
    return events;
  }, [chartData]);
  
  // Calculate average for selected range
  const averageEC = useMemo(() => {
    if (filteredReadings.length === 0) return 0;
    const sum = filteredReadings.reduce((acc, r) => acc + r.ec, 0);
    return (sum / filteredReadings.length).toFixed(0);
  }, [filteredReadings]);

  // Calculate 7-day average
  const average7d = useMemo(() => {
    const now = Date.now();
    const sevenDaysAgo = now - (7 * 24 * 60 * 60 * 1000);
    const sevenDayReadings = readings.filter((r) => r.timestamp >= sevenDaysAgo);
    if (sevenDayReadings.length === 0) return 0;
    const sum = sevenDayReadings.reduce((acc, r) => acc + r.ec, 0);
    return (sum / sevenDayReadings.length).toFixed(0);
  }, [readings]);

  // Extract EC values for statistics
  const ecValues = useMemo(() => {
    return filteredReadings.map((r) => r.ec);
  }, [filteredReadings]);
  
  const currentEC = latestReading?.ec ?? 0;
  
  // Determine status based on typical range (now in μS/cm)
  const getStatus = (value: number) => {
    if (value < 1000 || value > 2000) return { label: "Warning", variant: "destructive" as const };
    if (value < 1200 || value > 1800) return { label: "Caution", variant: "secondary" as const };
    return { label: "Normal", variant: "default" as const };
  };
  
  const status = getStatus(currentEC);
  
  if (isLoading && readings.length === 0) {
    return <div className="max-w-7xl mx-auto space-y-6">Loading...</div>;
  }

  return (
    <div className="max-w-7xl mx-auto space-y-6">
      {/* EC Stats */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Card>
          <CardHeader>
            <CardTitle>Current EC</CardTitle>
            <CardDescription>Real-time measurement</CardDescription>
          </CardHeader>
          <CardContent>
            <div className="flex items-baseline gap-2">
              <span className="text-3xl">{currentEC.toFixed(0)}</span>
              <span className="text-muted-foreground">μS/cm</span>
            </div>
            <Badge className="mt-2" variant={status.variant}>{status.label}</Badge>
            {latestReading?.ecDosingFlag === 1 && (
              <Badge className="mt-2 ml-2 bg-amber-500">Dosing Active</Badge>
            )}
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>7-Day Average</CardTitle>
            <CardDescription>Weekly average</CardDescription>
          </CardHeader>
          <CardContent>
            <div className="flex items-baseline gap-2">
              <span className="text-3xl">{average7d}</span>
              <span className="text-muted-foreground">μS/cm</span>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Optimal Range</CardTitle>
            <CardDescription>Target values</CardDescription>
          </CardHeader>
          <CardContent>
            <div className="flex items-baseline gap-2">
              <span className="text-3xl">1200 - 1800</span>
              <span className="text-muted-foreground">μS/cm</span>
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Statistics Card */}
      <StatisticsCard title="EC" data={ecValues} unit="μS/cm" color="teal" decimals={0} />

      {/* EC Chart */}
      <Card>
        <CardHeader>
          <CardTitle>EC Monitoring</CardTitle>
          <CardDescription>
            Electrical Conductivity over the last 24 hours.
            {" "}Vertical lines show dosing start (green), stop (red), and already active (blue).
          </CardDescription>
        </CardHeader>
        <CardContent>
          <ResponsiveContainer width="100%" height={400}>
            <LineChart data={chartData}>
              <CartesianGrid strokeDasharray="3 3" className="stroke-border" />
              <XAxis dataKey="time" className="text-xs" />
              <YAxis className="text-xs" domain={[0, 2500]} />
              <Tooltip 
                contentStyle={{ 
                  backgroundColor: 'hsl(var(--card))', 
                  border: '1px solid hsl(var(--border))',
                  borderRadius: '8px',
                  color: 'hsl(var(--foreground))'
                }}
              />
              <Legend />
              
              {/* Dosing start lines (green) */}
              {dosingEvents.filter(e => e.type === 'start').map((event, idx) => (
                <ReferenceLine
                  key={`start-${idx}`}
                  x={event.time}
                  stroke="#10b981"
                  strokeDasharray="3 3"
                  strokeWidth={2}
                  label={{ value: 'Start', position: 'top', fill: '#10b981', fontSize: 12 }}
                />
              ))}
              
              {/* Already active marker (blue) */}
              {dosingEvents.filter(e => e.type === 'active').map((event, idx) => (
                <ReferenceLine
                  key={`active-${idx}`}
                  x={event.time}
                  stroke="#3b82f6"
                  strokeDasharray="5 5"
                  strokeWidth={2}
                  label={{ value: 'Active', position: 'top', fill: '#3b82f6', fontSize: 12 }}
                />
              ))}
              
              {/* Dosing stop lines (red) */}
              {dosingEvents.filter(e => e.type === 'stop').map((event, idx) => (
                <ReferenceLine
                  key={`stop-${idx}`}
                  x={event.time}
                  stroke="#ef4444"
                  strokeDasharray="3 3"
                  strokeWidth={2}
                  label={{ value: 'Stop', position: 'top', fill: '#ef4444', fontSize: 12 }}
                />
              ))}
              
              <Line 
                type="monotone" 
                dataKey="ec" 
                stroke="#f59e0b" 
                strokeWidth={3}
                name="EC (μS/cm)"
                dot={{ fill: '#f59e0b', r: 4 }}
                isAnimationActive={false}
              />
            </LineChart>
          </ResponsiveContainer>
        </CardContent>
      </Card>


    </div>
  );
}
